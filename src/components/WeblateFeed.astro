---
// WeblateFeed.astro
interface Props {
    href?: string;
    interval?: number;
}

const {
    href = "https://weblate.geroriki.dpdns.org/exports/rss/yoodexy-mod/map/",
    interval = 5000
} = Astro.props;
---

<div class="weblate-widget">
    <header class="widget-header">
        <div class="header-title">
            <h2>פעילות אחרונה ב- Weblate</h2>
        </div>
        <div class="live-badge">
            <span class="pulse-dot"></span>
            <span>מעודכן</span>
        </div>
    </header>

    <div id="rss-viewer" class="widget-content">
        <div class="skeleton-row"><div class="skeleton-time"></div><div class="skeleton-text"><div class="skeleton-line"></div><div class="skeleton-line short"></div></div></div>
        <div class="skeleton-row"><div class="skeleton-time"></div><div class="skeleton-text"><div class="skeleton-line"></div><div class="skeleton-line short"></div></div></div>
    </div>

    <footer class="widget-footer">
        <span id="status-bar">מתחבר ל- Weblate...</span>
    </footer>
</div>

<script define:vars={{ href, interval }}>
    const PROXY_URL = 'https://corsproxy.io/?';

    function extractUser(description) {
        if (!description) return "מערכת";
        const match = description.match(/<span>(.*?)<\/span>/);
        return match ? match[1] : "משתמש";
    }

    function classifyAction(title) {
        if (title.includes("הצעה"))       return { icon: "✦", cls: "action-suggest" };
        if (title.includes("צילום מסך"))  return { icon: "⬡", cls: "action-screenshot" };
        if (title.includes("תרגום"))      return { icon: "◈", cls: "action-translate" };
        if (title.includes("אושר"))       return { icon: "◉", cls: "action-approve" };
        return                                   { icon: "◇", cls: "action-default" };
    }

    async function fetchRSS() {
        const viewer = document.getElementById('rss-viewer');
        const statusBar = document.getElementById('status-bar');
        if (!viewer) return;

        try {
            const cacheBuster = `&_t=${Date.now()}`;
            const finalUrl = PROXY_URL + encodeURIComponent(href + (href.includes('?') ? '&' : '?') + cacheBuster);

            const response = await fetch(finalUrl, { cache: 'no-store' });
            if (!response.ok) throw new Error();

            const str = await response.text();
            const data = new window.DOMParser().parseFromString(str, "text/xml");
            const items = data.querySelectorAll("item");

            if (items.length === 0) {
                viewer.innerHTML = `<div class="empty-state"><p>אין פעילות חדשה</p></div>`;
                return;
            }

            let html = "";
            items.forEach(el => {
                const title   = el.getElementsByTagName("title")[0]?.textContent   || "";
                const link    = el.getElementsByTagName("link")[0]?.textContent    || "#";
                const pubDate = el.getElementsByTagName("pubDate")[0]?.textContent;
                const desc    = el.getElementsByTagName("description")[0]?.textContent;

                const userName = extractUser(desc);
                const { icon, cls } = classifyAction(title);
                const dateObj = new Date(pubDate);
                const time = dateObj.toLocaleTimeString('he-IL', { hour: '2-digit', minute: '2-digit' });
                const date = dateObj.toLocaleDateString('he-IL', { day: '2-digit', month: '2-digit' });

                html += `
                    <a href="${link}" target="_blank" rel="noopener noreferrer" class="update-item ${cls}">
                        <div class="time-block">
                            <span class="action-icon">${icon}</span>
                            <span class="time">${time}</span>
                            <span class="date">${date}</span>
                        </div>
                        <div class="content-block">
                            <p class="title">${title}</p>
                            <div class="meta-row">
                                <span class="user-avatar">${userName.charAt(0).toUpperCase()}</span>
                                <span class="user-name">${userName}</span>
                            </div>
                        </div>
                        <span class="arrow-hint">›</span>
                    </a>
                `;
            });

            viewer.innerHTML = html;
            statusBar.textContent = `עודכן הרגע (${new Date().toLocaleTimeString('he-IL', { hour: '2-digit', minute: '2-digit', second: '2-digit' })})`;
            statusBar.style.color = "var(--text-muted)";

        } catch (error) {
            statusBar.textContent = "שגיאה בסנכרון הנתונים";
            statusBar.style.color = "#ef4444";
        }
    }

    fetchRSS();
    setInterval(fetchRSS, interval);
</script>

<style is:global>
    :root {
        --bg-color:      #ffffff;
        --border-color:  #eaeaea;
        --text-main:     #111827;
        --text-muted:    #6b7280;
        --primary:       #10b981;
        --primary-bg:    #ecfdf5;
        --hover-bg:      #f9fafb;

        --c-suggest:    #6366f1;
        --c-suggest-bg: #eef2ff;
        --c-shot:       #f59e0b;
        --c-shot-bg:    #fffbeb;
        --c-translate:  #10b981;
        --c-translate-bg: #ecfdf5;
        --c-approve:    #3b82f6;
        --c-approve-bg: #eff6ff;
        --c-default:    #8b5cf6;
        --c-default-bg: #f5f3ff;
    }

    .weblate-widget {
        background: var(--bg-color);
        border: 1px solid var(--border-color);
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.04);
        /* max-width: 420px; */
        width: 95%;
        margin: 16px auto;
        direction: rtl;
        font-family: system-ui, -apple-system, sans-serif;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

    .widget-header {
        padding: 16px 20px;
        border-bottom: 1px solid var(--border-color);
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #fafafa;
    }
    .header-title h2 { font-size: 1rem; color: var(--text-main); margin: 0; font-weight: 600; }

    .live-badge {
        display: flex; align-items: center; gap: 6px;
        background: var(--primary-bg); padding: 4px 10px;
        border-radius: 99px; font-size: 0.75rem; color: var(--primary); font-weight: 700;
    }
    .pulse-dot {
        width: 8px; height: 8px; background-color: var(--primary);
        border-radius: 50%; position: relative;
    }
    .pulse-dot::after {
        content: ''; position: absolute; width: 100%; height: 100%; top: 0; left: 0;
        background-color: var(--primary); border-radius: 50%;
        animation: pulse 2s infinite;
    }
    @keyframes pulse {
        0%   { transform: scale(1);   opacity: 0.8; }
        100% { transform: scale(2.5); opacity: 0;   }
    }

    .widget-content {
        max-height: 380px;
        overflow-y: auto;
        direction: rtl;
    }
    .widget-content::-webkit-scrollbar { width: 4px; }
    .widget-content::-webkit-scrollbar-thumb { background: #e5e7eb; border-radius: 10px; }

    .update-item {
        direction: rtl;
        display: flex;
        align-items: center;
        padding: 14px 20px 14px 16px;
        border-bottom: 1px solid var(--border-color);
        text-decoration: none;
        gap: 14px;
        position: relative;
        transition: background 0.18s ease;
        border-right: 3px solid transparent;
    }
    .update-item:hover {
        background: var(--hover-bg);
    }

    .action-suggest    { border-right-color: var(--c-suggest);   }
    .action-screenshot { border-right-color: var(--c-shot);      }
    .action-translate  { border-right-color: var(--c-translate); }
    .action-approve    { border-right-color: var(--c-approve);   }
    .action-default    { border-right-color: var(--c-default);   }

    .time-block {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2px;
        min-width: 52px;
        padding-left: 14px;
        border-left: 1px solid #f0f0f0;
    }

    .action-icon {
        font-size: 0.7rem;
        line-height: 1;
        opacity: 0.5;
        margin-bottom: 2px;
    }
    .action-suggest    .action-icon { color: var(--c-suggest);   opacity: 1; }
    .action-screenshot .action-icon { color: var(--c-shot);      opacity: 1; }
    .action-translate  .action-icon { color: var(--c-translate); opacity: 1; }
    .action-approve    .action-icon { color: var(--c-approve);   opacity: 1; }
    .action-default    .action-icon { color: var(--c-default);   opacity: 1; }

    .time {
        font-size: 0.82rem;
        font-weight: 700;
        color: var(--text-main);
        letter-spacing: -0.3px;
    }
    .date {
        font-size: 0.65rem;
        color: var(--text-muted);
        letter-spacing: 0.2px;
    }

    .content-block {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 6px;
        min-width: 0;
    }

    .title {
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--text-main);
        margin: 0;
        line-height: 1.35;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .meta-row {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .user-avatar {
        width: 18px;
        height: 18px;
        border-radius: 50%;
        background: var(--primary-bg);
        color: var(--primary);
        font-size: 0.6rem;
        font-weight: 800;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        line-height: 1;
    }

    .action-suggest    .user-avatar { background: var(--c-suggest-bg);   color: var(--c-suggest);   }
    .action-screenshot .user-avatar { background: var(--c-shot-bg);      color: var(--c-shot);      }
    .action-translate  .user-avatar { background: var(--c-translate-bg); color: var(--c-translate); }
    .action-approve    .user-avatar { background: var(--c-approve-bg);   color: var(--c-approve);   }
    .action-default    .user-avatar { background: var(--c-default-bg);   color: var(--c-default);   }

    .user-name {
        font-size: 0.72rem;
        color: var(--text-muted);
        font-weight: 500;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .arrow-hint {
        font-size: 1rem;
        color: #d1d5db;
        line-height: 1;
        transition: color 0.18s ease, transform 0.18s ease;
        flex-shrink: 0;
        transform: none;
        margin-left: -2px;
    }
    .update-item:hover .arrow-hint {
        color: var(--primary);
        transform: translateX(3px);
    }

    .widget-footer { padding: 10px 20px; background: #fafafa; border-top: 1px solid var(--border-color); }
    #status-bar { font-size: 0.7rem; color: var(--text-muted); text-align: right; display: block; }

    .skeleton-row { direction: rtl; display: flex; padding: 16px 20px; gap: 16px; border-bottom: 1px solid var(--border-color); }
    .skeleton-time { width: 40px; height: 40px; background: #f3f4f6; border-radius: 6px; animation: shimmer 1.5s infinite; }
    .skeleton-text { flex: 1; display: flex; flex-direction: column; gap: 8px; }
    .skeleton-line { height: 10px; background: #f3f4f6; border-radius: 4px; animation: shimmer 1.5s infinite; }
    .skeleton-line.short { width: 60%; }

    @keyframes shimmer {
        0%, 100% { opacity: 1; }
        50%       { opacity: 0.5; }
    }
</style>